# Environment Configuration Template
# Copy this file to .env and fill in your actual API keys

# Required: Firecrawl API Key for web scraping
# Get yours at: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# LLM: which provider to use — google | groq | openai (must match the API key you set below)
# LLM_PROVIDER=google

# Google AI (Gemini) - Get yours at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq - Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# Optional OpenAI-compatible API base URL (proxies, Azure, etc.)
# OPENAI_BASE_URL=

# Optional: Application Settings (uncomment to override defaults)
# DEBUG_MODE=false
# ENABLE_CACHING=true
# MODEL_TEMPERATURE=0.3
# CACHE_TTL_HOURS=24
# MAX_CACHE_SIZE=100
